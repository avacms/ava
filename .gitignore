# Ava CMS

# Dependencies
/vendor/

# Storage (regenerated at runtime)
/storage/cache/
/storage/logs/
/storage/tmp/
/storage/auth_attempts.json
/storage/auth_username_attempts.json

# Keep storage structure but ignore contents
!/storage/
!/storage/README.md
!/storage/redirects.json

# Environment and secrets
.env
.env.local
.env.*.local

# User credentials (sensitive)
app/config/users.php

# Logs
*.log

# OS files
.DS_Store
Thumbs.db
.directory

# Custom plugins (developed as separate repos)
app/plugins/*/
!app/plugins/feed/
!app/plugins/sitemap/
!app/plugins/redirects/

# Static site generator output
/dist/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# PHP
*.phar
.php-cs-fixer.cache
.phpunit.result.cache
